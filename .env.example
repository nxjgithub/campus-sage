APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/csage.db

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=csage_
VECTOR_BACKEND=memory
VECTOR_DIM=1024

VLLM_BASE_URL=http://127.0.0.1:8001/v1
VLLM_MODEL_NAME=Qwen2.5-7B-Instruct
VLLM_TIMEOUT_S=60
VLLM_ENABLED=false

EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_BATCH_SIZE=32

RERANK_ENABLED=false
RERANK_MODEL_NAME=bge-reranker

RAG_TOPK=5
RAG_THRESHOLD=0.25
RAG_MAX_CONTEXT_TOKENS=3000
RAG_MAX_SNIPPET_CHARS=200
RAG_MIN_EVIDENCE_CHUNKS=1
CHUNK_SIZE=500
CHUNK_OVERLAP=100

STORAGE_DIR=./data/storage
UPLOAD_MAX_MB=30
UPLOAD_ALLOWED_EXTS=pdf

REDIS_URL=redis://127.0.0.1:6379/0
INGEST_QUEUE_NAME=ingest
INGEST_QUEUE_ENABLED=false
INGEST_QUEUE_TIMEOUT_S=600
INGEST_QUEUE_RETRY_MAX=2
INGEST_QUEUE_RETRY_INTERVAL_S=60
INGEST_QUEUE_DEAD_NAME=ingest_dead
INGEST_QUEUE_RESULT_TTL_S=86400
INGEST_QUEUE_FAILURE_TTL_S=604800
INGEST_QUEUE_TTL_S=86400
INGEST_QUEUE_DASHBOARD_ENABLED=false
INGEST_QUEUE_ALERT_THRESHOLD=200
INGEST_QUEUE_DEAD_MAX=200

DEBUG_MODE=false
ENABLE_SWAGGER=true
