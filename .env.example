APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/csage.db

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=csage_
QDRANT_TIMEOUT_S=30
QDRANT_UPSERT_BATCH_SIZE=128
VECTOR_BACKEND=qdrant
VECTOR_DIM=1024

VLLM_BASE_URL=http://127.0.0.1:8001/v1
VLLM_MODEL_NAME=Qwen2.5-7B-Instruct
VLLM_TIMEOUT_S=60
VLLM_API_KEY=
VLLM_ENABLED=false

JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ISSUER=csage
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

EMBEDDING_BACKEND=http
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_PATH=/embeddings
EMBEDDING_TIMEOUT_S=60
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSIONS=
LOCAL_EMBEDDING_MODEL_NAME=BAAI/bge-m3
LOCAL_EMBEDDING_DEVICE=cpu
LOCAL_EMBEDDING_NORMALIZE=true

RERANK_ENABLED=false
RERANK_MODEL_NAME=bge-reranker

RAG_TOPK=5
RAG_THRESHOLD=0.25
RAG_MAX_CONTEXT_TOKENS=3000
RAG_MAX_SNIPPET_CHARS=200
RAG_MIN_EVIDENCE_CHUNKS=1
RAG_MIN_CONTEXT_CHARS=20
RAG_MIN_KEYWORD_COVERAGE=0.3
RAG_RERANK_CANDIDATE_MULTIPLIER=4
RAG_RERANK_CANDIDATE_CAP=40
RAG_STALE_WARNING_DAYS=730
CHUNK_SIZE=500
CHUNK_OVERLAP=100

STORAGE_DIR=./data/storage
UPLOAD_MAX_MB=30
UPLOAD_ALLOWED_EXTS=pdf,docx,html,htm,md,txt

REDIS_URL=redis://127.0.0.1:6379/0
INGEST_QUEUE_NAME=ingest
INGEST_QUEUE_ENABLED=false
INGEST_QUEUE_TIMEOUT_S=600
INGEST_QUEUE_RETRY_MAX=2
INGEST_QUEUE_RETRY_INTERVAL_S=60
INGEST_QUEUE_DEAD_NAME=ingest_dead
INGEST_QUEUE_RESULT_TTL_S=86400
INGEST_QUEUE_FAILURE_TTL_S=604800
INGEST_QUEUE_TTL_S=86400
INGEST_QUEUE_DASHBOARD_ENABLED=false
INGEST_QUEUE_ALERT_THRESHOLD=200
INGEST_QUEUE_FAILED_ALERT_THRESHOLD=10
INGEST_QUEUE_DEAD_MAX=200

DEBUG_MODE=false
ENABLE_SWAGGER=true
